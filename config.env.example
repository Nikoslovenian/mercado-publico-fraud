# Copia este archivo como .env y completa los valores

# Ticket de API de Mercado Publico (obtener en: https://api.mercadopublico.cl/modules/Participa.aspx)
MERCADOPUBLICO_TICKET=tu_ticket_aqui

# Ruta de la base de datos SQLite (por defecto: data/mercado_publico.db)
DB_PATH=../data/mercado_publico.db
